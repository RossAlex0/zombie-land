generator client {
  provider = "prisma-client"
  output   = "./generated"
}

datasource db {
  provider = "postgresql"
}

model activity {
  id                Int                 @id @default(autoincrement())
  name              String              @db.VarChar(100)
  description       String?
  picture           String?             @db.VarChar(255)
  status            String              @default("open") @db.VarChar(50)
  created_at        DateTime            @default(now()) @db.Timestamp(6)
  updated_at        DateTime            @default(now()) @db.Timestamp(6)
  category_activity category_activity[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model booking {
  id         Int      @id @default(autoincrement())
  status     String   @default("pending") @db.VarChar(50)
  start_at   DateTime @db.Date
  end_at     DateTime @db.Date
  duration   Int
  user_id    Int
  created_at DateTime @default(now()) @db.Timestamp(6)
  updated_at DateTime @default(now()) @db.Timestamp(6)
  discount   Decimal  @db.Decimal(10, 2)
  promo_code String?
  subtotal   Decimal  @db.Decimal(10, 2)
  total_paid Decimal  @db.Decimal(10, 2)
  reference  String   @unique @db.VarChar(50)
  user       user     @relation(fields: [user_id], references: [id], onUpdate: NoAction, map: "fk_booking_user")
  ticket     ticket[]
}

model category {
  id                Int                 @id @default(autoincrement())
  label             String              @unique @db.VarChar(100)
  created_at        DateTime            @default(now()) @db.Timestamp(6)
  updated_at        DateTime            @default(now()) @db.Timestamp(6)
  category_activity category_activity[]
}

model category_activity {
  activity_id Int
  category_id Int
  created_at  DateTime @default(now()) @db.Timestamp(6)
  activity    activity @relation(fields: [activity_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_ca_activity")
  category    category @relation(fields: [category_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_ca_category")

  @@id([activity_id, category_id])
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model configuration {
  id            Int      @id @default(1)
  entry_price   Decimal  @db.Decimal(10, 2)
  capacity      Int
  status        String   @default("active") @db.VarChar(50)
  opening_hours DateTime @db.Time(6)
  closing_hours DateTime @db.Time(6)
  created_at    DateTime @default(now()) @db.Timestamp(6)
  updated_at    DateTime @default(now()) @db.Timestamp(6)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model ticket_category {
  id            Int      @id @default(autoincrement())
  label         String   @unique @db.VarChar(100)
  reduction     Int      @default(0)
  is_default    Boolean  @default(false)
  display_order Int      @default(0)
  created_at    DateTime @default(now()) @db.Timestamp(6)
  updated_at    DateTime @default(now()) @db.Timestamp(6)
  ticket        ticket[]
}

model role {
  id         Int      @id @default(autoincrement())
  name       String   @unique @db.VarChar(50)
  created_at DateTime @default(now()) @db.Timestamp(6)
  user       user[]
}

model ticket {
  id                 Int             @id @default(autoincrement())
  reservation_number String          @unique @db.VarChar(50)
  status             String          @default("valid") @db.VarChar(50)
  validity_date      DateTime        @db.Timestamp(6)
  booking_id         Int
  created_at         DateTime        @default(now()) @db.Timestamp(6)
  updated_at         DateTime        @default(now()) @db.Timestamp(6)
  unit_price         Decimal         @db.Decimal(10, 2)
  category_id        Int
  booking            booking         @relation(fields: [booking_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_ticket_booking")
  category           ticket_category @relation(fields: [category_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_ticket_category")
}

model user {
  id                  Int             @id @default(autoincrement())
  first_name          String          @db.VarChar(100)
  last_name           String          @db.VarChar(100)
  email               String          @unique @db.VarChar(255)
  valid_email         Boolean?        @default(false)
  birth_date          DateTime?       @db.Date
  password            String          @db.VarChar(255)
  role_id             Int             @default(1)
  password_changed_at DateTime?       @db.Timestamp(6)
  created_at          DateTime        @default(now()) @db.Timestamp(6)
  updated_at          DateTime        @default(now()) @db.Timestamp(6)
  deleted_at          DateTime?       @db.Timestamp(6)
  deleted             Boolean         @default(false)
  stripe_customer_id  String?         @unique @db.VarChar(255)
  booking             booking[]
  refresh_token       refresh_token[]
  role                role            @relation(fields: [role_id], references: [id], onUpdate: NoAction, map: "fk_user_role")

  @@index([deleted_at])
}

model refresh_token {
  id         Int      @id @default(autoincrement())
  token      String   @unique
  issued_at  DateTime @default(now()) @db.Timestamp(6)
  expired_at DateTime @db.Timestamp(6)
  user_id    Int
  user       user     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_refresh_token_user")
}
